{
    "manifest_version": 3,
    "name": "S2N Scanner",
    "version": "0.1.0",
    "key": "",
    "description": "S2N 취약점 스캐너 Chrome Extension GUI",
    "permissions": [
        "nativeMessaging",
        "storage",
        "tabs"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "options_page": "options.html",
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}